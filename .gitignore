# =========================
# Project-Specific Files
# =========================

# Environment variables (CRITICAL: Prevents leaking OpenAI API key)
.env

# Persistent Vector Database (Prevents committing large binary database files)
chroma_data/
chroma_data_ollama/

# Optional: Ignore local test documents so you don't accidentally commit personal files
*.pdf
*.txt
# !sample_document.txt  # Uncomment this to specifically allow a sample file
!requirements.txt  # Ensure requirements.txt is tracked for dependencies
# =========================
# Python & Environments
# =========================

# Virtual environments
.venv/
venv/
env/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# =========================
# OS-Specific Files
# =========================

# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini